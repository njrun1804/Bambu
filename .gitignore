.DS_Store
.venv/
__pycache__/
*.pyc
.pytest_cache/
.coverage
.serena/
.freecad-runtime/
result.json
dist/
build/
*.egg-info/

# Public repo safety: keep personal source photos, printer secrets, and local
# project work out of git.
private/
projects/*/photos/*
!projects/*/photos/.gitkeep
projects/*/mesh/*
!projects/*/mesh/.gitkeep
!projects/*/mesh/NEXT_STEPS.md
!projects/*/mesh/provenance.yaml
.env
*.local.json
*.local.yaml
*.local.yml

# Generated printable outputs can be recreated from tracked briefs.
outputs/*
!outputs/.gitkeep
*.stl
*.3mf
*.gcode
*.gcode.3mf
*.png
!projects/*/references/ai-concepts/*.png
